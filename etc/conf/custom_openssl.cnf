openssl_conf = openssl_init

[openssl_init]
ssl_conf = ssl_sect

[ssl_sect]
system_default = system_default_sect

[system_default_sect]
# 配置允许的 TLS 组 - 排除 ffdhe2048，包含更强的 DH 组
# 注意：仅适用于 OpenSSL 3.0+，因为 TLS 1.3 中的 FFDH 组支持从 3.0 开始
Groups = x25519:prime256v1:x448:secp521r1:secp384r1:ffdhe3072:ffdhe4096:ffdhe6144:ffdhe8192